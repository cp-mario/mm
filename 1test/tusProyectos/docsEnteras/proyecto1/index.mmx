# MMX Documentation


# Tabla modo vertical (default)
#table v striped
Nombre|Puntaje|Estado
Alice|95|Pass
Bob|87|Pass
#endtable

# Tabla modo horizontal
#table h
Nombre|Puntaje|Estado
Alice|95|Pass
Bob|87|Pass
#endtable

# Tabla modo ambos (b) - con esquina vacía
#table b
          Nombre|Puntaje
Rendimiento ayer|Alice|95
Rendimiento hoy |Bob|87
#endtable

# Tabla sin modo explícito (equivale a v)
#table
Título|Descripción
Item 1|Texto abajo
Item 2|Más texto
#endtable




